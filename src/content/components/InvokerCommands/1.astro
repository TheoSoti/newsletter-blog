<section class="invoker-demo" aria-label="Invoker commands demo">
	<div class="invoker-demo__panel">
		<p class="invoker-demo__title">Dialog</p>
		<button type="button" class="button invoker-demo__button" command="show-modal" commandfor="confirm-delete">
			Open dialog
		</button>

		<dialog id="confirm-delete" class="invoker-demo__dialog" aria-labelledby="confirm-delete-title">
			<p id="confirm-delete-title" class="invoker-demo__dialog-title">Dialog</p>
			<p>Opened with HTML.</p>
			<div class="invoker-demo__actions">
				<button type="button" class="button" command="close" commandfor="confirm-delete">Close</button>
			</div>
		</dialog>
	</div>

	<div class="invoker-demo__panel">
		<p class="invoker-demo__title">Popover</p>
		<button
			type="button"
			class="button invoker-demo__button invoker-demo__button--popover"
			command="toggle-popover"
			commandfor="profile-menu"
		>
			Open popover
		</button>

		<div id="profile-menu" class="invoker-demo__popover" popover>
			<p>Opened with HTML.</p>
			<button type="button" class="button" command="hide-popover" commandfor="profile-menu">Close</button>
		</div>
	</div>
</section>

