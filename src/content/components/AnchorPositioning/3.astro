		color: white;
	}

	.anchor-fallback-lab__code {
		margin: 0;
		border: 1px solid rgb(240 246 252 / 0.16);
		background: #0d1117;
		color: #c9d1d9;
		border-radius: 8px;
		padding: 0.75rem;
		overflow: auto;
		font-size: 0.78rem;
		white-space: pre;
	}

	.anchor-fallback-lab__code code {
		color: inherit;
	}

	.anchor-fallback-lab__code :global(.token-selector) {
		color: #7ee787;
	}

	.anchor-fallback-lab__code :global(.token-property) {
		color: #79c0ff;
	}

	.anchor-fallback-lab__code :global(.token-function) {
		color: #d2a8ff;
	}

	.anchor-fallback-lab__code :global(.token-keyword) {
		color: #ff7b72;
	}

	@supports not (anchor-name: --fallback-trigger) {
		.anchor-fallback-lab__menu {
