<section class="anchor-fallback-lab" data-anchor-fallback-lab aria-label="Interactive position fallback demo">
	<div class="anchor-fallback-lab__stage">
		<div class="anchor-fallback-lab__viewport">
			<span class="anchor-fallback-lab__trigger">Anchor</span>
			<div class="anchor-fallback-lab__menu">
				<p>Preferred: bottom</p>
				<p>Fallback: flip-block, flip-inline</p>
			</div>
		</div>

		<div class="anchor-fallback-lab__controls" aria-label="Move the trigger">
			<button type="button" data-place="center" class="is-active">center</button>
			<button type="button" data-place="bottom">near bottom</button>
			<button type="button" data-place="right">near right</button>
			<button type="button" data-place="corner">corner</button>
		</div>
	</div>

	<pre class="anchor-fallback-lab__code"><code>.menu &#123;
  position-area: bottom;
  position-try-fallbacks: flip-block, flip-inline;
&#125;</code></pre>
</section>

<script is:inline>
	document.querySelectorAll('[data-anchor-fallback-lab]').forEach((demo) => {
		const viewport = demo.querySelector('.anchor-fallback-lab__viewport');
		const code = demo.querySelector('.anchor-fallback-lab__code code');
		const controls = demo.querySelectorAll('.anchor-fallback-lab__controls button');
		const highlightCss = (value) => {
			const escapeHtml = (text) =>
				text.replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;');
			const highlightValue = (text) =>
				escapeHtml(text)
					.replace(/\b(flip-block|flip-inline)\b/g, '<span class="token-function">$1</span>')
					.replace(/\b(top|right|bottom|left|center)\b/g, '<span class="token-keyword">$1</span>');

			return value
				.split('\n')
				.map((line) => {
					const selector = line.match(/^(\s*)([.#][\w-]+)(\s*\{)$/);
					if (selector) {
						return `${selector[1]}<span class="token-selector">${selector[2]}</span>${selector[3]}`;
					}

					const declaration = line.match(/^(\s*)([\w-]+):\s*(.*);$/);
					if (declaration) {
						return `${declaration[1]}<span class="token-property">${declaration[2]}</span>: ${highlightValue(
							declaration[3],
						)};`;
					}

					return escapeHtml(line);
				})
				.join('\n');
		};

		code.innerHTML = highlightCss(`.menu {
  position-area: bottom;
  position-try-fallbacks: flip-block, flip-inline;
}`);

		controls.forEach((control) => {
			control.addEventListener('click', () => {
				viewport.dataset.place = control.dataset.place;
				controls.forEach((item) => item.classList.toggle('is-active', item === control));
			});
		});
	});
</script>

<style>
	.anchor-fallback-lab {
		display: grid;
		gap: 0.75rem;
		padding: 0.75rem;
		background: var(--bg-light);
	}

	.anchor-fallback-lab__stage {
		border: 2px solid color-mix(in srgb, deeppink 70%, transparent);
		background: var(--bg);
		padding: 0.75rem;
		display: grid;
		gap: 0.6rem;
	}

	.anchor-fallback-lab__viewport {
		min-height: 330px;
		border: 2px dashed color-mix(in srgb, deeppink 75%, var(--border));
		background:
			linear-gradient(90deg, rgb(255 20 147 / 0.08) 1px, transparent 1px),
			linear-gradient(rgb(255 20 147 / 0.08) 1px, transparent 1px),
			var(--bg-light);
		background-size: 28px 28px;
		position: relative;
		overflow: clip;
	}

	.anchor-fallback-lab__trigger {
		position: absolute;
		left: 50%;
		top: 46%;
		translate: -50% -50%;
		border: 2px solid var(--border);
		background: var(--bg);
		color: var(--text);
		font: inherit;
		font-weight: 700;
		padding: 0.38rem 0.7rem;
		anchor-name: --fallback-trigger;
		transition:
			left 0.25s ease,
			top 0.25s ease,
			translate 0.25s ease;
	}

	.anchor-fallback-lab__viewport[data-place='bottom'] .anchor-fallback-lab__trigger {
		top: calc(100% - 2.4rem);
	}

	.anchor-fallback-lab__viewport[data-place='right'] .anchor-fallback-lab__trigger {
		left: calc(100% - 4.6rem);
		top: 46%;
	}

	.anchor-fallback-lab__viewport[data-place='corner'] .anchor-fallback-lab__trigger {
		left: calc(100% - 4.6rem);
		top: calc(100% - 2.4rem);
	}

	.anchor-fallback-lab__menu {
		position: absolute;
		position-anchor: --fallback-trigger;
		position-area: bottom;
		position-try-fallbacks: flip-block, flip-inline, flip-block flip-inline;
		margin: 0.45rem;
		width: 190px;
		border: 2px solid color-mix(in srgb, deeppink 78%, var(--border));
		background: color-mix(in srgb, deeppink 12%, white);
		box-shadow: 0 8px 22px rgb(255 20 147 / 0.18);
		padding: 0.6rem;
		display: grid;
		gap: 0.35rem;
	}

	.anchor-fallback-lab__menu p {
		margin: 0;
	}

	.anchor-fallback-lab__menu p:first-child {
		font-weight: 700;
	}

	.anchor-fallback-lab__controls {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.35rem;
	}

	.anchor-fallback-lab__controls button {
		border: 1px solid rgb(23 23 23 / 0.28);
		border-radius: 999px;
		background: rgb(255 255 255 / 0.72);
		color: inherit;
		font: inherit;
		font-size: 0.72rem;
		line-height: 1;
		padding: 0.34rem 0.56rem;
		cursor: pointer;
	}

	.anchor-fallback-lab__controls button.is-active {
		border-color: transparent;
