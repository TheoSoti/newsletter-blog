---
import type { CollectionEntry } from 'astro:content';
import { getContentSlug } from '../../utils/contentSlug';
import { getShortSlug } from '../../utils/shortSlug';

type Post = CollectionEntry<'blog'> | CollectionEntry<'short'>;

type Props = {
	posts: Post[];
	type: 'blog' | 'short';
};

const { posts, type } = Astro.props as Props;

const getPostSlug = (post: Post) => (type === 'short' ? getShortSlug(post.id) : getContentSlug(post.id));
const listName = type === 'blog' ? 'Blog Articles' : 'Short Articles';
const itemListOrder = 'https://schema.org/ItemListOrderDescending';

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: listName,
	url: new URL(Astro.url.pathname, Astro.site),
	numberOfItems: posts.length,
	itemListOrder,
	itemListElement: (posts || []).map((post, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: post.data.title,
		url: `https://theosoti.com/${type}/${getPostSlug(post)}/`,
	})),
};
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />
