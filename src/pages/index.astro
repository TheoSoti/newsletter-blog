---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SocialProofStats from '../components/SocialProofStats.astro';
import BookShowcase from '../components/BookShowcase.astro';
import Card from '../components/Card.astro';
import ShortList from '../components/ShortList.astro';
import Newsletter from '../components/Newsletter.astro';

import { getCollection } from 'astro:content';
import ItemList from '../components/microdatas/ItemList.astro';

const HOME_TITLE = 'Learn Modern CSS with Theo Soti';
const HOME_DESCRIPTION =
	'Learn modern CSS with practical tutorials, real UI examples, and short guides about modern CSS, HTML, and front-end development.';

const posts = (await getCollection('blog'))
	.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf())
	.slice(-6)
	.reverse();

const shorts = (await getCollection('short'))
	.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf())
	.slice(-9)
	.reverse();
---

<html lang="en">
	<head>
		<BaseHead title={HOME_TITLE} description={HOME_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<Hero />
		<SocialProofStats />
		<BookShowcase />

		<main>
			<section>
				<h2>Latest Blog Articles</h2>
				<p>
					Read practical modern CSS articles built around real interface problems. <br />
					These longer reads show how CSS and HTML features can simplify layouts, interactions, and UI details.
				</p>
				<ul>
					{posts.map((post) => <Card post={post} width="720" height="360" />)}
				</ul>
				<a href="/blog/" class="button"> View more articles </a>
			</section>

			<section>
				<h2>Latest Short Articles</h2>
				<p>
					Looking for quick modern CSS tips? <br />These short articles take less than a minute to read when you
					want one focused idea without opening a full tutorial.
				</p>
				<ul>
					{shorts.map((short) => <ShortList post={short} />)}
				</ul>
				<a href="/short/" class="button"> View more articles </a>
			</section>
		</main>
		<Newsletter />
		<Footer />
		<ItemList posts={posts} type="blog" />
		<ItemList posts={shorts} type="short" />
	</body>
</html>

<style>
	main {
		padding: 1em 0 1.5em;
	}
	section:first-child {
		margin-bottom: 3em;
	}
	h2 {
		margin-top: 0;
	}
	ul {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
		list-style-type: none;
		padding: 0;
		margin-bottom: 0;
	}
	.button {
		padding: 0.3em 0.5em;
		margin: 1.5em auto 0;
		display: flex;
		width: fit-content;
		justify-content: center;
		text-decoration: none;
	}
	.button:hover {
		color: var(--white);
	}
	@media (min-width: 600px) {
		main {
			padding: 2em 0 2.5em;
		}
		ul {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1024px) {
		ul {
			grid-template-columns: 1fr 1fr 1fr;
		}
	}
</style>
